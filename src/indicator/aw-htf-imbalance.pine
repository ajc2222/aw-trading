//@version=6
indicator("AW HTF Imbalance", overlay=true, max_bars_back=500)

// ═══════════════════════════════════════════════════════════════════
// SETTINGS
// ═══════════════════════════════════════════════════════════════════
g = "HTF Imbalance"
show_htf_box = input.bool(true, "Show HTF FVG",                     group=g)
zone_col    = input.color(color.new(#888888, 70), "Zone Color",    group=g)
show_label  = input.bool(true, "Show Label",                        group=g)
label_col   = input.color(color.white, "Label Color",               group=g)
label_size  = input.string("small", "Label Size",
               options=["tiny","small","normal","large"],            group=g)
lookback    = input.int(100, "Lookback (HTF bars)",
               minval=10, maxval=500,                                group=g)
extend_bars = input.int(3, "Extend Bars Right",
               minval=1, maxval=50,                                  group=g)

g2 = "Current TF FVG"
show_tf_box = input.bool(true, "Show Current TF FVG",               group=g2)
tf_zone_col = input.color(color.new(color.gray, 50), "Zone Color",  group=g2)

// ═══════════════════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════════════════
f_size(string s) =>
    switch s
        "tiny"   => size.tiny
        "small"  => size.small
        "normal" => size.normal
        "large"  => size.large
        => size.small

f_tf_label(string tf) =>
    if tf == "D"
        "Daily"
    else if tf == "W"
        "Weekly"
    else if tf == "M"
        "Monthly"
    else
        float mins = str.tonumber(tf)
        if not na(mins) and mins >= 60 and int(mins) % 60 == 0
            str.tostring(int(mins / 60)) + "h"
        else
            tf + "m"

// ═══════════════════════════════════════════════════════════════════
// FVG SCAN — runs in HTF context via request.security()
// Returns 3 most recent non-inverted FVGs as flat tuple:
//   [top1, bot1, time1, top2, bot2, time2, top3, bot3, time3]
// ═══════════════════════════════════════════════════════════════════
f_scan(int lb) =>
    float t1  = na
    float b1  = na
    int   tm1 = na
    float t2  = na
    float b2  = na
    int   tm2 = na
    float t3  = na
    float b3  = na
    int   tm3 = na
    int   found = 0

    for i = 1 to lb
        if found >= 3
            break
        if na(high[i + 2])
            break

        // ── Bullish FVG: bar[i] low > bar[i+2] high ──────────────
        if low[i] > high[i + 2]
            float bot = high[i + 2]
            float top = low[i]
            bool  inv = false
            if i > 0
                for j = 0 to i - 1
                    if close[j] < bot
                        inv := true
                        break
            if not inv
                if found == 0
                    t1  := top
                    b1  := bot
                    tm1 := time[i + 1]
                else if found == 1
                    t2  := top
                    b2  := bot
                    tm2 := time[i + 1]
                else
                    t3  := top
                    b3  := bot
                    tm3 := time[i + 1]
                found += 1

        // ── Bearish FVG: bar[i] high < bar[i+2] low ──────────────
        if found < 3 and high[i] < low[i + 2]
            float top = low[i + 2]
            float bot = high[i]
            bool  inv = false
            if i > 0
                for j = 0 to i - 1
                    if close[j] > top
                        inv := true
                        break
            if not inv
                if found == 0
                    t1  := top
                    b1  := bot
                    tm1 := time[i + 1]
                else if found == 1
                    t2  := top
                    b2  := bot
                    tm2 := time[i + 1]
                else
                    t3  := top
                    b3  := bot
                    tm3 := time[i + 1]
                found += 1

    [t1, b1, tm1, t2, b2, tm2, t3, b3, tm3]

// ═══════════════════════════════════════════════════════════════════
// CURRENT TF SCAN — runs on chart timeframe directly
// Returns:
//   at/ab/atm  = FVG price is currently inside (active)
//   mt/mb/mtm  = most recent FVG price has wicked into but isn't
//                currently inside and hasn't been inverted (mitigated)
// ═══════════════════════════════════════════════════════════════════
f_scan_tf(int lb) =>
    float at  = na
    float ab  = na
    int   atm = na
    float mt  = na
    float mb  = na
    int   mtm = na

    for i = 1 to lb
        if not na(at) and not na(mt)
            break
        if na(high[i + 2])
            break

        // ── Bullish FVG ───────────────────────────────────────────
        if low[i] > high[i + 2]
            float bot     = high[i + 2]
            float top     = low[i]
            bool  inv     = false
            bool  touched = false
            for j = 0 to i - 1
                if close[j] < bot
                    inv := true
                    break
                if not touched and low[j] <= top and high[j] >= bot
                    touched := true
            if not inv
                if close >= bot and close <= top
                    if na(at)
                        at  := top
                        ab  := bot
                        atm := time[i + 1]
                else if touched and na(mt)
                    mt  := top
                    mb  := bot
                    mtm := time[i + 1]

        // ── Bearish FVG ───────────────────────────────────────────
        if high[i] < low[i + 2]
            float top     = low[i + 2]
            float bot     = high[i]
            bool  inv     = false
            bool  touched = false
            for j = 0 to i - 1
                if close[j] > top
                    inv := true
                    break
                if not touched and low[j] <= top and high[j] >= bot
                    touched := true
            if not inv
                if close >= bot and close <= top
                    if na(at)
                        at  := top
                        ab  := bot
                        atm := time[i + 1]
                else if touched and na(mt)
                    mt  := top
                    mb  := bot
                    mtm := time[i + 1]

    [at, ab, atm, mt, mb, mtm]

// ═══════════════════════════════════════════════════════════════════
// HTF DATA — top level, no lookahead
// ═══════════════════════════════════════════════════════════════════
[t1_d,  b1_d,  tm1_d,  t2_d,  b2_d,  tm2_d,  t3_d,  b3_d,  tm3_d]  = request.security(syminfo.tickerid, "D",   f_scan(lookback), lookahead=barmerge.lookahead_off)
[t1_4h, b1_4h, tm1_4h, t2_4h, b2_4h, tm2_4h, t3_4h, b3_4h, tm3_4h] = request.security(syminfo.tickerid, "240", f_scan(lookback), lookahead=barmerge.lookahead_off)
[t1_1h, b1_1h, tm1_1h, t2_1h, b2_1h, tm2_1h, t3_1h, b3_1h, tm3_1h] = request.security(syminfo.tickerid, "60",  f_scan(lookback), lookahead=barmerge.lookahead_off)
[t1_30, b1_30, tm1_30, t2_30, b2_30, tm2_30, t3_30, b3_30, tm3_30]  = request.security(syminfo.tickerid, "30",  f_scan(lookback), lookahead=barmerge.lookahead_off)
[t1_15, b1_15, tm1_15, t2_15, b2_15, tm2_15, t3_15, b3_15, tm3_15]  = request.security(syminfo.tickerid, "15",  f_scan(lookback), lookahead=barmerge.lookahead_off)
[t1_5,  b1_5,  tm1_5,  t2_5,  b2_5,  tm2_5,  t3_5,  b3_5,  tm3_5]  = request.security(syminfo.tickerid, "5",   f_scan(lookback), lookahead=barmerge.lookahead_off)

// ═══════════════════════════════════════════════════════════════════
// TOP-DOWN RESOLUTION
// Walk D → 4H → 1H → 30m → 15m → 5m
// ═══════════════════════════════════════════════════════════════════
f_in(float t, float b) => not na(t) and close >= b and close <= t

f_resolve(float t1, float b1, int tm1,
          float t2, float b2, int tm2,
          float t3, float b3, int tm3) =>
    float zt  = na
    float zb  = na
    int   ztm = na
    if f_in(t1, b1)
        zt  := t1
        zb  := b1
        ztm := tm1
    else if f_in(t2, b2)
        zt  := t2
        zb  := b2
        ztm := tm2
    else if f_in(t3, b3)
        zt  := t3
        zb  := b3
        ztm := tm3
    [zt, zb, ztm]

f_best(float t1, float b1, int tm1,
       float t2, float b2, int tm2,
       float t3, float b3, int tm3) =>
    float zt  = na
    float zb  = na
    int   ztm = na
    if not na(t1)
        zt  := t1
        zb  := b1
        ztm := tm1
    else if not na(t2)
        zt  := t2
        zb  := b2
        ztm := tm2
    else if not na(t3)
        zt  := t3
        zb  := b3
        ztm := tm3
    [zt, zb, ztm]

// Check each TF in priority order — price-inside first
float  act_top = na
float  act_bot = na
int    act_tm  = na
string act_lbl = na
string act_tf  = na

[rd_t,  rd_b,  rd_tm]  = f_resolve(t1_d,  b1_d,  tm1_d,  t2_d,  b2_d,  tm2_d,  t3_d,  b3_d,  tm3_d)
[r4_t,  r4_b,  r4_tm]  = f_resolve(t1_4h, b1_4h, tm1_4h, t2_4h, b2_4h, tm2_4h, t3_4h, b3_4h, tm3_4h)
[r1_t,  r1_b,  r1_tm]  = f_resolve(t1_1h, b1_1h, tm1_1h, t2_1h, b2_1h, tm2_1h, t3_1h, b3_1h, tm3_1h)
[r30_t, r30_b, r30_tm] = f_resolve(t1_30, b1_30, tm1_30, t2_30, b2_30, tm2_30, t3_30, b3_30, tm3_30)
[r15_t, r15_b, r15_tm] = f_resolve(t1_15, b1_15, tm1_15, t2_15, b2_15, tm2_15, t3_15, b3_15, tm3_15)
[r5_t,  r5_b,  r5_tm]  = f_resolve(t1_5,  b1_5,  tm1_5,  t2_5,  b2_5,  tm2_5,  t3_5,  b3_5,  tm3_5)

if not na(rd_t)
    act_top := rd_t
    act_bot := rd_b
    act_tm  := rd_tm
    act_lbl := "Daily"
    act_tf  := "D"
else if not na(r4_t)
    act_top := r4_t
    act_bot := r4_b
    act_tm  := r4_tm
    act_lbl := "4h"
    act_tf  := "240"
else if not na(r1_t)
    act_top := r1_t
    act_bot := r1_b
    act_tm  := r1_tm
    act_lbl := "1h"
    act_tf  := "60"
else if not na(r30_t)
    act_top := r30_t
    act_bot := r30_b
    act_tm  := r30_tm
    act_lbl := "30m"
    act_tf  := "30"
else if not na(r15_t)
    act_top := r15_t
    act_bot := r15_b
    act_tm  := r15_tm
    act_lbl := "15m"
    act_tf  := "15"
else if not na(r5_t)
    act_top := r5_t
    act_bot := r5_b
    act_tm  := r5_tm
    act_lbl := "5m"
    act_tf  := "5"

// Fallback: if price not inside any zone, show most recent non-inverted FVG
if na(act_top)
    [fd_t,  fd_b,  fd_tm]  = f_best(t1_d,  b1_d,  tm1_d,  t2_d,  b2_d,  tm2_d,  t3_d,  b3_d,  tm3_d)
    [f4_t,  f4_b,  f4_tm]  = f_best(t1_4h, b1_4h, tm1_4h, t2_4h, b2_4h, tm2_4h, t3_4h, b3_4h, tm3_4h)
    [f1_t,  f1_b,  f1_tm]  = f_best(t1_1h, b1_1h, tm1_1h, t2_1h, b2_1h, tm2_1h, t3_1h, b3_1h, tm3_1h)
    [f30_t, f30_b, f30_tm] = f_best(t1_30, b1_30, tm1_30, t2_30, b2_30, tm2_30, t3_30, b3_30, tm3_30)
    [f15_t, f15_b, f15_tm] = f_best(t1_15, b1_15, tm1_15, t2_15, b2_15, tm2_15, t3_15, b3_15, tm3_15)
    [f5_t,  f5_b,  f5_tm]  = f_best(t1_5,  b1_5,  tm1_5,  t2_5,  b2_5,  tm2_5,  t3_5,  b3_5,  tm3_5)
    if not na(fd_t)
        act_top := fd_t
        act_bot := fd_b
        act_tm  := fd_tm
        act_lbl := "Daily"
        act_tf  := "D"
    else if not na(f4_t)
        act_top := f4_t
        act_bot := f4_b
        act_tm  := f4_tm
        act_lbl := "4h"
        act_tf  := "240"
    else if not na(f1_t)
        act_top := f1_t
        act_bot := f1_b
        act_tm  := f1_tm
        act_lbl := "1h"
        act_tf  := "60"
    else if not na(f30_t)
        act_top := f30_t
        act_bot := f30_b
        act_tm  := f30_tm
        act_lbl := "30m"
        act_tf  := "30"
    else if not na(f15_t)
        act_top := f15_t
        act_bot := f15_b
        act_tm  := f15_tm
        act_lbl := "15m"
        act_tf  := "15"
    else if not na(f5_t)
        act_top := f5_t
        act_bot := f5_b
        act_tm  := f5_tm
        act_lbl := "5m"
        act_tf  := "5"

// ═══════════════════════════════════════════════════════════════════
// CURRENT TF — active zone or most recent mitigated zone
// ═══════════════════════════════════════════════════════════════════
[tf_at, tf_ab, tf_atm, tf_mt, tf_mb, tf_mtm] = f_scan_tf(lookback)

float tf_top = na
float tf_bot = na
int   tf_tm  = na

if not na(tf_at)
    tf_top := tf_at
    tf_bot := tf_ab
    tf_tm  := tf_atm
else if not na(tf_mt)
    tf_top := tf_mt
    tf_bot := tf_mb
    tf_tm  := tf_mtm

// Suppress Box 2 when current TF is the same as Box 1's resolved TF
bool draw_tf_box = show_tf_box and not na(tf_top)

// ═══════════════════════════════════════════════════════════════════
// DISPLAY — Box 1: HTF priority, Box 2: current TF
// ═══════════════════════════════════════════════════════════════════
var box   active_box  = na
var float prev_top    = na
var float prev_bot    = na

var box   tf_box      = na
var float tf_prev_top = na
var float tf_prev_bot = na

right_ms = timenow + timeframe.in_seconds() * 1000 * extend_bars

// — Box 1 (HTF) ——————————————————————————————————————————————————
zone_changed = act_top != prev_top or act_bot != prev_bot
zone_active  = show_htf_box and not na(act_top)

if zone_active
    if na(active_box) or zone_changed
        if not na(active_box)
            box.delete(active_box)
        active_box := box.new(
             left         = act_tm,
             top          = act_top,
             right        = right_ms,
             bottom       = act_bot,
             xloc         = xloc.bar_time,
             bgcolor      = zone_col,
             border_color = color.new(color.white, 100),
             border_width = 0,
             text         = show_label ? act_lbl : "",
             text_color   = label_col,
             text_size    = f_size(label_size),
             text_halign  = text.align_right,
             text_valign  = text.align_center)
        prev_top := act_top
        prev_bot := act_bot
    else
        box.set_right(active_box, right_ms)
else
    if not na(active_box)
        box.delete(active_box)
        active_box := na
    prev_top := na
    prev_bot := na

// — Box 2 (Current TF) ———————————————————————————————————————————
tf_changed = tf_top != tf_prev_top or tf_bot != tf_prev_bot

if draw_tf_box
    if na(tf_box) or tf_changed
        if not na(tf_box)
            box.delete(tf_box)
        tf_box := box.new(
             left         = tf_tm,
             top          = tf_top,
             right        = right_ms,
             bottom       = tf_bot,
             xloc         = xloc.bar_time,
             bgcolor      = tf_zone_col,
             border_color = color.new(color.white, 100),
             border_width = 0,
             text         = show_label ? f_tf_label(timeframe.period) : "",
             text_color   = label_col,
             text_size    = f_size(label_size),
             text_halign  = text.align_right,
             text_valign  = text.align_center)
        tf_prev_top := tf_top
        tf_prev_bot := tf_bot
    else
        box.set_right(tf_box, right_ms)
else
    if not na(tf_box)
        box.delete(tf_box)
        tf_box := na
    tf_prev_top := na
    tf_prev_bot := na
