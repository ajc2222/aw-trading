//@version=6
// AW Trailing Stop — Protected Levels
// Setup: a bullish FVG forms, price taps into it, then the next bullish CISD
// that forms after the tap becomes the protected low (swing low of that CISD).
// Vice versa for bearish.
indicator("AW Trailing Stop — Protected Levels", overlay=true, max_lines_count=200, max_labels_count=100)

// ─── Settings ──────────────────────────────────────────────────────────────
var string G = "Trailing Stop"
enable       = input.bool(true,     "Enable",               group=G)
line_width   = input.int(2,         "Line Width",           group=G, minval=1, maxval=4)
color_bull   = input.color(#26a69a, "Protected Low Color",  group=G)
color_bear   = input.color(#ef5350, "Protected High Color", group=G)

var string GL = "Labels"
show_lbl     = input.bool(true,              "Show Level Labels",  group=GL)
lbl_bull     = input.string("Protected Low",  "Bull Label Text",   group=GL)
lbl_bear     = input.string("Protected High", "Bear Label Text",   group=GL)
lbl_size_str = input.string("Small",          "Label Size",        group=GL, options=["Tiny","Small","Normal","Large"])

var string GC = "CISD / Swing Detection"
cisd_window  = input.int(4,  "Trigger Window",  group=GC, minval=1, maxval=20)
max_leg      = input.int(10, "Max Leg Length",  group=GC, minval=1, maxval=30)

lbl_sz = switch lbl_size_str
    "Tiny"   => size.tiny
    "Small"  => size.small
    "Normal" => size.normal
    "Large"  => size.large
    => size.small

// ─── Active FVG zone arrays (current TF) ───────────────────────────────────
var float[] bull_fvg_bot = array.new_float(0)
var float[] bull_fvg_top = array.new_float(0)
var float[] bear_fvg_bot = array.new_float(0)
var float[] bear_fvg_top = array.new_float(0)

// Flags: true once any active FVG of that direction has been tapped by price
var bool bull_fvg_tapped = false
var bool bear_fvg_tapped = false

// ─── CISD pending state ────────────────────────────────────────────────────
lowest_10  = ta.lowest(low,  10)[1]
highest_10 = ta.highest(high, 10)[1]

var bool  pend_bull      = false
var int   pend_bull_bar  = 0
var float pend_bull_cisd = na
var float pend_bull_low  = na

var bool  pend_bear      = false
var int   pend_bear_bar  = 0
var float pend_bear_cisd = na
var float pend_bear_high = na

// ─── Trail state ───────────────────────────────────────────────────────────
var line  bull_ln  = na
var label bull_lbl = na
var float bull_lvl = na
var int   bull_x1  = na

var line  bear_ln  = na
var label bear_lbl = na
var float bear_lvl = na
var int   bear_x1  = na

// ─── Per-bar logic ─────────────────────────────────────────────────────────
if barstate.isconfirmed

    // 1. Detect new FVGs
    if low > high[2]
        array.push(bull_fvg_bot, high[2])
        array.push(bull_fvg_top, low)
    if high < low[2]
        array.push(bear_fvg_bot, high)
        array.push(bear_fvg_top, low[2])

    // 2. Purge fully-inversed FVGs; reset tap flag if no active FVGs remain
    int nb = array.size(bull_fvg_bot)
    if nb > 0
        for i = nb - 1 to 0
            if close < array.get(bull_fvg_bot, i)
                array.remove(bull_fvg_bot, i)
                array.remove(bull_fvg_top, i)
    if array.size(bull_fvg_bot) == 0
        bull_fvg_tapped := false

    int nbr = array.size(bear_fvg_bot)
    if nbr > 0
        for i = nbr - 1 to 0
            if close > array.get(bear_fvg_top, i)
                array.remove(bear_fvg_bot, i)
                array.remove(bear_fvg_top, i)
    if array.size(bear_fvg_bot) == 0
        bear_fvg_tapped := false

    // 3. Check if price is tapping into an active FVG this bar
    int nbu = array.size(bull_fvg_bot)
    if nbu > 0
        for i = 0 to nbu - 1
            // Bull FVG tap: price's low enters the zone from above
            if low <= array.get(bull_fvg_top, i)
                bull_fvg_tapped := true
                break

    int nbea = array.size(bear_fvg_bot)
    if nbea > 0
        for i = 0 to nbea - 1
            // Bear FVG tap: price's high enters the zone from below
            if high >= array.get(bear_fvg_bot, i)
                bear_fvg_tapped := true
                break

    // 4. CISD swing detection — only fires after an FVG tap
    float recent_swing_low = na
    for j = 2 to 50
        if close[j] < open[j] and close[j-1] > open[j-1]
            recent_swing_low := math.min(low[j], low[j-1])
            break

    float recent_swing_high = na
    for j = 2 to 50
        if close[j] > open[j] and close[j-1] < open[j-1]
            recent_swing_high := math.max(high[j], high[j-1])
            break

    is_lower_low   = low[0]  < lowest_10  or (not na(recent_swing_low)  and low[0]  < recent_swing_low)
    is_higher_high = high[0] > highest_10 or (not na(recent_swing_high) and high[0] > recent_swing_high)

    if is_lower_low and bull_fvg_tapped
        int   bear_start   = -1
        float highest_open = na

        for j = 1 to 50
            if close[j] < open[j]
                bear_start := j
                break

        if bear_start >= 0
            for j = bear_start to bear_start + max_leg - 1
                if close[j] < open[j]
                    if na(highest_open) or open[j] > highest_open
                        highest_open := open[j]
                else
                    break

        if not na(highest_open)
            pend_bull      := true
            pend_bull_bar  := bar_index
            pend_bull_cisd := highest_open
            pend_bull_low  := low[0]

    if is_higher_high and bear_fvg_tapped
        int   bull_start  = -1
        float lowest_open = na

        for j = 1 to 50
            if close[j] > open[j]
                bull_start := j
                break

        if bull_start >= 0
            for j = bull_start to bull_start + max_leg - 1
                if close[j] > open[j]
                    if na(lowest_open) or open[j] < lowest_open
                        lowest_open := open[j]
                else
                    break

        if not na(lowest_open)
            pend_bear      := true
            pend_bear_bar  := bar_index
            pend_bear_cisd := lowest_open
            pend_bear_high := high[0]

// ─── Drawing logic ─────────────────────────────────────────────────────────
if enable and barstate.isconfirmed

    if not na(bull_ln)
        line.set_x2(bull_ln, bar_index)
    if not na(bull_lbl)
        label.set_x(bull_lbl, bar_index)
    if not na(bear_ln)
        line.set_x2(bear_ln, bar_index)
    if not na(bear_lbl)
        label.set_x(bear_lbl, bar_index)

    if not na(bull_ln) and not na(bull_lvl) and close < bull_lvl
        line.delete(bull_ln)
        label.delete(bull_lbl)
        bull_ln  := na
        bull_lbl := na
        bull_lvl := na
        bull_x1  := na

    if not na(bear_ln) and not na(bear_lvl) and close > bear_lvl
        line.delete(bear_ln)
        label.delete(bear_lbl)
        bear_ln  := na
        bear_lbl := na
        bear_lvl := na
        bear_x1  := na

    if pend_bull
        bars_since = bar_index - pend_bull_bar
        if bars_since >= 0 and bars_since <= cisd_window
            if close > pend_bull_cisd
                line.delete(bull_ln)
                label.delete(bull_lbl)
                bull_lvl        := pend_bull_low
                bull_x1         := pend_bull_bar
                bull_ln         := line.new(bull_x1, bull_lvl, bar_index, bull_lvl,
                                            color=color_bull, width=line_width)
                bull_lbl        := show_lbl ?
                     label.new(bar_index, bull_lvl, lbl_bull, yloc=yloc.price,
                               style=label.style_label_left, color=color.new(color_bull, 100),
                               textcolor=color_bull, size=lbl_sz) : na
                pend_bull       := false
                bull_fvg_tapped := false
        else if bars_since > cisd_window
            pend_bull := false

    if pend_bear
        bars_since = bar_index - pend_bear_bar
        if bars_since >= 0 and bars_since <= cisd_window
            if close < pend_bear_cisd
                line.delete(bear_ln)
                label.delete(bear_lbl)
                bear_lvl        := pend_bear_high
                bear_x1         := pend_bear_bar
                bear_ln         := line.new(bear_x1, bear_lvl, bar_index, bear_lvl,
                                            color=color_bear, width=line_width)
                bear_lbl        := show_lbl ?
                     label.new(bar_index, bear_lvl, lbl_bear, yloc=yloc.price,
                               style=label.style_label_left, color=color.new(color_bear, 100),
                               textcolor=color_bear, size=lbl_sz) : na
                pend_bear       := false
                bear_fvg_tapped := false
        else if bars_since > cisd_window
            pend_bear := false
