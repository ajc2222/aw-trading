//@version=6
// AW HTF FVG — Exit-Triggered Mitigation
// Tracks unmitigated portions of FVGs across HTF and current TF.
// While outside zone: always shows full original zone (first touch stays visible).
// While inside zone (re-entry after partial mitigation): shows remaining unmitigated portion.
// vbound updates only when price closes back outside — exit-triggered, not tick-by-tick.
indicator("AW HTF FVG", overlay=true, max_bars_back=500, max_boxes_count=500)

// ═══ UDT ══════════════════════════════════════════════════════════════════
type Zone
    float  top        // original upper edge — fixed
    float  bot        // original lower edge — fixed
    float  vbound     // vtop (bull, shrinks down) or vbot (bear, rises up)
    bool   in_zone    // price currently overlapping the remaining zone
    float  extreme    // min_low (bull) or max_high (bear) while in_zone
    int    start_time // ms timestamp of FVG center candle — unique ID
    int    det_bar    // bar_index at registration (for current TF expiry)
    box    drawn_box
    bool   is_bull
    string tf_label
    bool   is_htf

var Zone[] zones          = array.new<Zone>()
var int[]  removed_times  = array.new_int()   // blacklist — prevents re-registration

// ═══ Settings ══════════════════════════════════════════════════════════════
var string GH = "HTF Settings"
show_daily   = input.bool(true,  "Show Daily",          group=GH)
show_4h      = input.bool(true,  "Show 4H",             group=GH)
show_1h      = input.bool(true,  "Show 1H",             group=GH)
show_30      = input.bool(false, "Show 30m",            group=GH)
show_15      = input.bool(false, "Show 15m",            group=GH)
show_5       = input.bool(false, "Show 5m",             group=GH)
htf_lookback = input.int(50,    "HTF Lookback (bars)",  group=GH, minval=5, maxval=200)
extend_bars  = input.int(5,     "Extend Bars Right",    group=GH, minval=1, maxval=50)

var string GT = "Current TF"
show_tf      = input.bool(true, "Show Current TF FVGs", group=GT)
tf_lookback  = input.int(100,   "Lookback (bars)",       group=GT, minval=10, maxval=500)
max_tf_zones = input.int(5,     "Max Zones",             group=GT, minval=1, maxval=20)

var string GL = "Labels"
show_label = input.bool(true,         "Show Labels",  group=GL)
label_col  = input.color(color.white, "Label Color",  group=GL)
label_size = input.string("small",    "Label Size",
              options=["tiny","small","normal","large"], group=GL)

var string GC = "Colors"
bull_col    = input.color(color.new(#089981, 75), "Bull — waiting",  group=GC)
bull_col_in = input.color(color.new(#089981, 40), "Bull — in zone",  group=GC)
bear_col    = input.color(color.new(#f23645, 75), "Bear — waiting",  group=GC)
bear_col_in = input.color(color.new(#f23645, 40), "Bear — in zone",  group=GC)

// ═══ Helpers ═══════════════════════════════════════════════════════════════
f_size(string s) =>
    switch s
        "tiny"   => size.tiny
        "small"  => size.small
        "normal" => size.normal
        "large"  => size.large
        => size.small

// ═══ HTF scanner ═══════════════════════════════════════════════════════════
// Up to 3 most recent non-inverted FVGs (bull + bear) from the HTF context.
// Inversion is checked at HTF bar level only (not current TF).
f_scan(int lb) =>
    float t1 = na
    float b1 = na
    int   m1 = na
    bool  u1 = false
    float t2 = na
    float b2 = na
    int   m2 = na
    bool  u2 = false
    float t3 = na
    float b3 = na
    int   m3 = na
    bool  u3 = false
    int   found = 0
    for i = 1 to lb
        if found >= 3 or na(high[i + 2])
            break
        // Bull FVG: gap up
        if low[i] > high[i + 2]
            float zt  = low[i]
            float zb  = high[i + 2]
            bool  inv = false
            for j = 0 to i - 1
                if close[j] < zb
                    inv := true
                    break
            if not inv
                if found == 0
                    t1 := zt
                    b1 := zb
                    m1 := time[i + 1]
                    u1 := true
                else if found == 1
                    t2 := zt
                    b2 := zb
                    m2 := time[i + 1]
                    u2 := true
                else
                    t3 := zt
                    b3 := zb
                    m3 := time[i + 1]
                    u3 := true
                found += 1
        // Bear FVG: gap down
        if found < 3 and high[i] < low[i + 2]
            float zt  = low[i + 2]
            float zb  = high[i]
            bool  inv = false
            for j = 0 to i - 1
                if close[j] > zt
                    inv := true
                    break
            if not inv
                if found == 0
                    t1 := zt
                    b1 := zb
                    m1 := time[i + 1]
                    u1 := false
                else if found == 1
                    t2 := zt
                    b2 := zb
                    m2 := time[i + 1]
                    u2 := false
                else
                    t3 := zt
                    b3 := zb
                    m3 := time[i + 1]
                    u3 := false
                found += 1
    [t1, b1, m1, u1, t2, b2, m2, u2, t3, b3, m3, u3]

// ═══ HTF data ══════════════════════════════════════════════════════════════
[t1_d,  b1_d,  m1_d,  u1_d,  t2_d,  b2_d,  m2_d,  u2_d,  t3_d,  b3_d,  m3_d,  u3_d]  = request.security(syminfo.tickerid, "D",   f_scan(htf_lookback), lookahead=barmerge.lookahead_off)
[t1_4h, b1_4h, m1_4h, u1_4h, t2_4h, b2_4h, m2_4h, u2_4h, t3_4h, b3_4h, m3_4h, u3_4h] = request.security(syminfo.tickerid, "240", f_scan(htf_lookback), lookahead=barmerge.lookahead_off)
[t1_1h, b1_1h, m1_1h, u1_1h, t2_1h, b2_1h, m2_1h, u2_1h, t3_1h, b3_1h, m3_1h, u3_1h] = request.security(syminfo.tickerid, "60",  f_scan(htf_lookback), lookahead=barmerge.lookahead_off)
[t1_30, b1_30, m1_30, u1_30, t2_30, b2_30, m2_30, u2_30, t3_30, b3_30, m3_30, u3_30]  = request.security(syminfo.tickerid, "30",  f_scan(htf_lookback), lookahead=barmerge.lookahead_off)
[t1_15, b1_15, m1_15, u1_15, t2_15, b2_15, m2_15, u2_15, t3_15, b3_15, m3_15, u3_15]  = request.security(syminfo.tickerid, "15",  f_scan(htf_lookback), lookahead=barmerge.lookahead_off)
[t1_5,  b1_5,  m1_5,  u1_5,  t2_5,  b2_5,  m2_5,  u2_5,  t3_5,  b3_5,  m3_5,  u3_5]  = request.security(syminfo.tickerid, "5",   f_scan(htf_lookback), lookahead=barmerge.lookahead_off)

// ═══ Zone registration ═════════════════════════════════════════════════════
// Adds a zone to the tracking array if not already registered or blacklisted.
// Arrays passed by reference — modifications are visible at call site.
f_register(Zone[] za, int[] ra, float ztop, float zbot, int st, bool bull, string lbl, bool htf) =>
    if not na(ztop) and not na(zbot) and not na(st)
        bool skip = false
        int  rn   = ra.size()
        if rn > 0
            for k = 0 to rn - 1
                if ra.get(k) == st
                    skip := true
                    break
        if not skip
            int zn = za.size()
            if zn > 0
                for k = 0 to zn - 1
                    if za.get(k).start_time == st
                        skip := true
                        break
        if not skip
            float vb = bull ? ztop : zbot
            int   rm = time + timeframe.in_seconds() * 1000 * extend_bars
            box b = box.new(st, ztop, rm, zbot,
                        xloc         = xloc.bar_time,
                        bgcolor      = bull ? bull_col : bear_col,
                        border_color = color.new(color.white, 100),
                        border_width = 0,
                        text         = show_label ? lbl : "",
                        text_color   = label_col,
                        text_size    = f_size(label_size),
                        text_halign  = text.align_right,
                        text_valign  = text.align_center)
            za.push(Zone.new(top=ztop, bot=zbot, vbound=vb,
                             in_zone=false, extreme=na,
                             start_time=st, det_bar=bar_index,
                             drawn_box=b, is_bull=bull,
                             tf_label=lbl, is_htf=htf))

// ═══ Confirmed-bar logic ═══════════════════════════════════════════════════
if barstate.isconfirmed

    // ── Current TF FVG detection ─────────────────────────────────────────
    if show_tf
        // Trim oldest current TF zone when at cap (before adding new one)
        int tf_cnt = 0
        int zs = zones.size()
        if zs > 0
            for k = 0 to zs - 1
                if not zones.get(k).is_htf
                    tf_cnt += 1
        if tf_cnt >= max_tf_zones and zs > 0
            for k = 0 to zs - 1
                Zone zk = zones.get(k)
                if not zk.is_htf
                    removed_times.push(zk.start_time)
                    box.delete(zk.drawn_box)
                    zones.remove(k)
                    break
        if low > high[2]
            f_register(zones, removed_times, low, high[2], time[1], true, timeframe.period, false)
        if high < low[2]
            f_register(zones, removed_times, low[2], high, time[1], false, timeframe.period, false)

    // ── HTF zone registration ─────────────────────────────────────────────
    if show_daily
        f_register(zones, removed_times, t1_d,  b1_d,  m1_d,  u1_d,  "D",  true)
        f_register(zones, removed_times, t2_d,  b2_d,  m2_d,  u2_d,  "D",  true)
        f_register(zones, removed_times, t3_d,  b3_d,  m3_d,  u3_d,  "D",  true)
    if show_4h
        f_register(zones, removed_times, t1_4h, b1_4h, m1_4h, u1_4h, "4H", true)
        f_register(zones, removed_times, t2_4h, b2_4h, m2_4h, u2_4h, "4H", true)
        f_register(zones, removed_times, t3_4h, b3_4h, m3_4h, u3_4h, "4H", true)
    if show_1h
        f_register(zones, removed_times, t1_1h, b1_1h, m1_1h, u1_1h, "1H", true)
        f_register(zones, removed_times, t2_1h, b2_1h, m2_1h, u2_1h, "1H", true)
        f_register(zones, removed_times, t3_1h, b3_1h, m3_1h, u3_1h, "1H", true)
    if show_30
        f_register(zones, removed_times, t1_30, b1_30, m1_30, u1_30, "30m", true)
        f_register(zones, removed_times, t2_30, b2_30, m2_30, u2_30, "30m", true)
        f_register(zones, removed_times, t3_30, b3_30, m3_30, u3_30, "30m", true)
    if show_15
        f_register(zones, removed_times, t1_15, b1_15, m1_15, u1_15, "15m", true)
        f_register(zones, removed_times, t2_15, b2_15, m2_15, u2_15, "15m", true)
        f_register(zones, removed_times, t3_15, b3_15, m3_15, u3_15, "15m", true)
    if show_5
        f_register(zones, removed_times, t1_5,  b1_5,  m1_5,  u1_5,  "5m", true)
        f_register(zones, removed_times, t2_5,  b2_5,  m2_5,  u2_5,  "5m", true)
        f_register(zones, removed_times, t3_5,  b3_5,  m3_5,  u3_5,  "5m", true)

    // ── Zone processing ───────────────────────────────────────────────────
    int n = zones.size()
    if n > 0
        for i = n - 1 to 0
            Zone z = zones.get(i)

            // Expiry: current TF zones only (HTF zones managed by scan output)
            if not z.is_htf and bar_index - z.det_bar > tf_lookback
                removed_times.push(z.start_time)
                box.delete(z.drawn_box)
                zones.remove(i)
                continue

            // Inversion: close through the fixed opposite edge — hard remove
            if (z.is_bull and close < z.bot) or (not z.is_bull and close > z.top)
                removed_times.push(z.start_time)
                box.delete(z.drawn_box)
                zones.remove(i)
                continue

            // Entry: candle overlaps the remaining unmitigated zone
            bool inside = false
            if z.is_bull
                inside := low <= z.vbound and high >= z.bot
            else
                inside := high >= z.vbound and low <= z.top

            if inside
                if not z.in_zone
                    z.in_zone := true
                    z.extreme  := z.is_bull ? low : high
                else
                    z.extreme  := z.is_bull ? math.min(z.extreme, low) : math.max(z.extreme, high)

            // Exit: close moved back outside the zone — update vbound
            // Fires even on same bar as entry (rejection wick case)
            bool exited = z.in_zone and (z.is_bull ? close > z.vbound : close < z.vbound)
            if exited
                float new_vb = z.extreme
                z.in_zone := false
                bool fully_done = z.is_bull ? new_vb <= z.bot : new_vb >= z.top
                if fully_done
                    // Fully mitigated
                    removed_times.push(z.start_time)
                    box.delete(z.drawn_box)
                    zones.remove(i)
                    continue
                z.vbound := new_vb

            // Box display:
            // - vbound == orig edge (no prior mitigation): always show full zone
            // - vbound < orig edge AND in_zone: show remaining zone only (re-entry)
            // - vbound < orig edge AND not in_zone: show full original (first touch still visible)
            bool show_rem = z.in_zone and (z.is_bull ? z.vbound < z.top : z.vbound > z.bot)
            color bg = z.in_zone ? (z.is_bull ? bull_col_in : bear_col_in) : (z.is_bull ? bull_col : bear_col)
            box.set_bgcolor(z.drawn_box, bg)
            if z.is_bull
                box.set_top(z.drawn_box, show_rem ? z.vbound : z.top)
            else
                box.set_bottom(z.drawn_box, show_rem ? z.vbound : z.bot)

    // Prevent removed_times from growing unbounded
    if removed_times.size() > 100
        removed_times.shift()

// ═══ Every bar: extend all boxes right ═════════════════════════════════════
int rms = time + timeframe.in_seconds() * 1000 * extend_bars
int n_e = zones.size()
if n_e > 0
    for i = 0 to n_e - 1
        Zone z = zones.get(i)
        if not na(z.drawn_box)
            box.set_right(z.drawn_box, rms)
