//@version=6
indicator("AW HTF FVG", overlay=true, max_bars_back=500)

// ═══════════════════════════════════════════════════════════════════
// SETTINGS
// ═══════════════════════════════════════════════════════════════════
g = "HTF FVG"
show_htf_box  = input.bool(true, "Show HTF FVG",                     group=g)
zone_col      = input.color(color.new(#888888, 70), "Zone Color",    group=g)
zone_col_in   = input.color(color.new(#888888, 40), "In-Zone Color", group=g)
show_label    = input.bool(true, "Show Label",                        group=g)
label_col     = input.color(color.white, "Label Color",               group=g)
label_size    = input.string("small", "Label Size",
                 options=["tiny","small","normal","large"],            group=g)
lookback      = input.int(100, "Lookback (HTF bars)",
                 minval=10, maxval=500,                                group=g)
extend_bars   = input.int(3, "Extend Bars Right",
                 minval=1, maxval=50,                                  group=g)

g2 = "Current TF FVG"
show_tf_box    = input.bool(true, "Show Current TF FVG",              group=g2)
tf_zone_col    = input.color(color.new(color.gray, 50), "Zone Color", group=g2)
tf_zone_col_in = input.color(color.new(color.gray, 30), "In-Zone Color", group=g2)

// ═══════════════════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════════════════
f_size(string s) =>
    switch s
        "tiny"   => size.tiny
        "small"  => size.small
        "normal" => size.normal
        "large"  => size.large
        => size.small

f_tf_label(string tf) =>
    if tf == "D"
        "Daily"
    else if tf == "W"
        "Weekly"
    else if tf == "M"
        "Monthly"
    else
        float mins = str.tonumber(tf)
        if not na(mins) and mins >= 60 and int(mins) % 60 == 0
            str.tostring(int(mins / 60)) + "h"
        else
            tf + "m"

// ═══════════════════════════════════════════════════════════════════
// HTF FVG SCAN
// Returns 3 most recent non-inverted FVGs + bull/bear direction.
// u* = true → bullish (gap up), false → bearish (gap down)
// ═══════════════════════════════════════════════════════════════════
f_scan(int lb) =>
    float t1  = na
    float b1  = na
    int   tm1 = na
    bool  u1  = false
    float t2  = na
    float b2  = na
    int   tm2 = na
    bool  u2  = false
    float t3  = na
    float b3  = na
    int   tm3 = na
    bool  u3  = false
    int   found = 0
    for i = 1 to lb
        if found >= 3
            break
        if na(high[i + 2])
            break
        if low[i] > high[i + 2]
            float bot = high[i + 2]
            float top = low[i]
            bool  inv = false
            if i > 0
                for j = 0 to i - 1
                    if close[j] < bot
                        inv := true
                        break
            if not inv
                if found == 0
                    t1  := top
                    b1  := bot
                    tm1 := time[i + 1]
                    u1  := true
                else if found == 1
                    t2  := top
                    b2  := bot
                    tm2 := time[i + 1]
                    u2  := true
                else
                    t3  := top
                    b3  := bot
                    tm3 := time[i + 1]
                    u3  := true
                found += 1
        if found < 3 and high[i] < low[i + 2]
            float top = low[i + 2]
            float bot = high[i]
            bool  inv = false
            if i > 0
                for j = 0 to i - 1
                    if close[j] > top
                        inv := true
                        break
            if not inv
                if found == 0
                    t1  := top
                    b1  := bot
                    tm1 := time[i + 1]
                    u1  := false
                else if found == 1
                    t2  := top
                    b2  := bot
                    tm2 := time[i + 1]
                    u2  := false
                else
                    t3  := top
                    b3  := bot
                    tm3 := time[i + 1]
                    u3  := false
                found += 1
    [t1, b1, tm1, u1, t2, b2, tm2, u2, t3, b3, tm3, u3]

// ═══════════════════════════════════════════════════════════════════
// CURRENT TF SCAN
// at* = FVG price is currently inside (active)
// mt* = most recent FVG price has touched but isn't currently inside
// ═══════════════════════════════════════════════════════════════════
f_scan_tf(int lb) =>
    float at    = na
    float ab    = na
    int   atm   = na
    bool  at_ub = false
    float mt    = na
    float mb    = na
    int   mtm   = na
    bool  mt_ub = false
    for i = 1 to lb
        if not na(at) and not na(mt)
            break
        if na(high[i + 2])
            break
        if low[i] > high[i + 2]
            float bot     = high[i + 2]
            float top     = low[i]
            bool  inv     = false
            bool  touched = false
            for j = 0 to i - 1
                if close[j] < bot
                    inv := true
                    break
                if not touched and low[j] <= top and high[j] >= bot
                    touched := true
            if not inv
                if close >= bot and close <= top
                    if na(at)
                        at    := top
                        ab    := bot
                        atm   := time[i + 1]
                        at_ub := true
                else if touched and na(mt)
                    mt    := top
                    mb    := bot
                    mtm   := time[i + 1]
                    mt_ub := true
        if high[i] < low[i + 2]
            float top     = low[i + 2]
            float bot     = high[i]
            bool  inv     = false
            bool  touched = false
            for j = 0 to i - 1
                if close[j] > top
                    inv := true
                    break
                if not touched and low[j] <= top and high[j] >= bot
                    touched := true
            if not inv
                if close >= bot and close <= top
                    if na(at)
                        at    := top
                        ab    := bot
                        atm   := time[i + 1]
                        at_ub := false
                else if touched and na(mt)
                    mt    := top
                    mb    := bot
                    mtm   := time[i + 1]
                    mt_ub := false
    [at, ab, atm, at_ub, mt, mb, mtm, mt_ub]

// ═══════════════════════════════════════════════════════════════════
// HTF DATA
// ═══════════════════════════════════════════════════════════════════
[t1_d,  b1_d,  tm1_d,  u1_d,  t2_d,  b2_d,  tm2_d,  u2_d,  t3_d,  b3_d,  tm3_d,  u3_d]  = request.security(syminfo.tickerid, "D",   f_scan(lookback), lookahead=barmerge.lookahead_off)
[t1_4h, b1_4h, tm1_4h, u1_4h, t2_4h, b2_4h, tm2_4h, u2_4h, t3_4h, b3_4h, tm3_4h, u3_4h] = request.security(syminfo.tickerid, "240", f_scan(lookback), lookahead=barmerge.lookahead_off)
[t1_1h, b1_1h, tm1_1h, u1_1h, t2_1h, b2_1h, tm2_1h, u2_1h, t3_1h, b3_1h, tm3_1h, u3_1h] = request.security(syminfo.tickerid, "60",  f_scan(lookback), lookahead=barmerge.lookahead_off)
[t1_30, b1_30, tm1_30, u1_30, t2_30, b2_30, tm2_30, u2_30, t3_30, b3_30, tm3_30, u3_30]  = request.security(syminfo.tickerid, "30",  f_scan(lookback), lookahead=barmerge.lookahead_off)
[t1_15, b1_15, tm1_15, u1_15, t2_15, b2_15, tm2_15, u2_15, t3_15, b3_15, tm3_15, u3_15]  = request.security(syminfo.tickerid, "15",  f_scan(lookback), lookahead=barmerge.lookahead_off)
[t1_5,  b1_5,  tm1_5,  u1_5,  t2_5,  b2_5,  tm2_5,  u2_5,  t3_5,  b3_5,  tm3_5,  u3_5]  = request.security(syminfo.tickerid, "5",   f_scan(lookback), lookahead=barmerge.lookahead_off)

// ═══════════════════════════════════════════════════════════════════
// TOP-DOWN RESOLUTION
// ═══════════════════════════════════════════════════════════════════
f_in(float t, float b) => not na(t) and close >= b and close <= t

f_resolve(float t1, float b1, int tm1, bool u1,
          float t2, float b2, int tm2, bool u2,
          float t3, float b3, int tm3, bool u3) =>
    float zt = na
    float zb = na
    int  ztm = na
    bool  zu = false
    if f_in(t1, b1)
        zt  := t1
        zb  := b1
        ztm := tm1
        zu  := u1
    else if f_in(t2, b2)
        zt  := t2
        zb  := b2
        ztm := tm2
        zu  := u2
    else if f_in(t3, b3)
        zt  := t3
        zb  := b3
        ztm := tm3
        zu  := u3
    [zt, zb, ztm, zu]

f_best(float t1, float b1, int tm1, bool u1,
       float t2, float b2, int tm2, bool u2,
       float t3, float b3, int tm3, bool u3) =>
    float zt = na
    float zb = na
    int  ztm = na
    bool  zu = false
    if not na(t1)
        zt  := t1
        zb  := b1
        ztm := tm1
        zu  := u1
    else if not na(t2)
        zt  := t2
        zb  := b2
        ztm := tm2
        zu  := u2
    else if not na(t3)
        zt  := t3
        zb  := b3
        ztm := tm3
        zu  := u3
    [zt, zb, ztm, zu]

[rd_t,  rd_b,  rd_tm,  rd_u]  = f_resolve(t1_d,  b1_d,  tm1_d,  u1_d,  t2_d,  b2_d,  tm2_d,  u2_d,  t3_d,  b3_d,  tm3_d,  u3_d)
[r4_t,  r4_b,  r4_tm,  r4_u]  = f_resolve(t1_4h, b1_4h, tm1_4h, u1_4h, t2_4h, b2_4h, tm2_4h, u2_4h, t3_4h, b3_4h, tm3_4h, u3_4h)
[r1_t,  r1_b,  r1_tm,  r1_u]  = f_resolve(t1_1h, b1_1h, tm1_1h, u1_1h, t2_1h, b2_1h, tm2_1h, u2_1h, t3_1h, b3_1h, tm3_1h, u3_1h)
[r30_t, r30_b, r30_tm, r30_u] = f_resolve(t1_30, b1_30, tm1_30, u1_30, t2_30, b2_30, tm2_30, u2_30, t3_30, b3_30, tm3_30, u3_30)
[r15_t, r15_b, r15_tm, r15_u] = f_resolve(t1_15, b1_15, tm1_15, u1_15, t2_15, b2_15, tm2_15, u2_15, t3_15, b3_15, tm3_15, u3_15)
[r5_t,  r5_b,  r5_tm,  r5_u]  = f_resolve(t1_5,  b1_5,  tm1_5,  u1_5,  t2_5,  b2_5,  tm2_5,  u2_5,  t3_5,  b3_5,  tm3_5,  u3_5)

float  act_top  = na
float  act_bot  = na
int    act_tm   = na
string act_lbl  = na
string act_tf   = na
bool   act_bull = false

if not na(rd_t)
    act_top  := rd_t
    act_bot  := rd_b
    act_tm   := rd_tm
    act_bull := rd_u
    act_lbl  := "Daily"
    act_tf   := "D"
else if not na(r4_t)
    act_top  := r4_t
    act_bot  := r4_b
    act_tm   := r4_tm
    act_bull := r4_u
    act_lbl  := "4h"
    act_tf   := "240"
else if not na(r1_t)
    act_top  := r1_t
    act_bot  := r1_b
    act_tm   := r1_tm
    act_bull := r1_u
    act_lbl  := "1h"
    act_tf   := "60"
else if not na(r30_t)
    act_top  := r30_t
    act_bot  := r30_b
    act_tm   := r30_tm
    act_bull := r30_u
    act_lbl  := "30m"
    act_tf   := "30"
else if not na(r15_t)
    act_top  := r15_t
    act_bot  := r15_b
    act_tm   := r15_tm
    act_bull := r15_u
    act_lbl  := "15m"
    act_tf   := "15"
else if not na(r5_t)
    act_top  := r5_t
    act_bot  := r5_b
    act_tm   := r5_tm
    act_bull := r5_u
    act_lbl  := "5m"
    act_tf   := "5"

if na(act_top)
    [fd_t,  fd_b,  fd_tm,  fd_u]  = f_best(t1_d,  b1_d,  tm1_d,  u1_d,  t2_d,  b2_d,  tm2_d,  u2_d,  t3_d,  b3_d,  tm3_d,  u3_d)
    [f4_t,  f4_b,  f4_tm,  f4_u]  = f_best(t1_4h, b1_4h, tm1_4h, u1_4h, t2_4h, b2_4h, tm2_4h, u2_4h, t3_4h, b3_4h, tm3_4h, u3_4h)
    [f1_t,  f1_b,  f1_tm,  f1_u]  = f_best(t1_1h, b1_1h, tm1_1h, u1_1h, t2_1h, b2_1h, tm2_1h, u2_1h, t3_1h, b3_1h, tm3_1h, u3_1h)
    [f30_t, f30_b, f30_tm, f30_u] = f_best(t1_30, b1_30, tm1_30, u1_30, t2_30, b2_30, tm2_30, u2_30, t3_30, b3_30, tm3_30, u3_30)
    [f15_t, f15_b, f15_tm, f15_u] = f_best(t1_15, b1_15, tm1_15, u1_15, t2_15, b2_15, tm2_15, u2_15, t3_15, b3_15, tm3_15, u3_15)
    [f5_t,  f5_b,  f5_tm,  f5_u]  = f_best(t1_5,  b1_5,  tm1_5,  u1_5,  t2_5,  b2_5,  tm2_5,  u2_5,  t3_5,  b3_5,  tm3_5,  u3_5)
    if not na(fd_t)
        act_top  := fd_t
        act_bot  := fd_b
        act_tm   := fd_tm
        act_bull := fd_u
        act_lbl  := "Daily"
        act_tf   := "D"
    else if not na(f4_t)
        act_top  := f4_t
        act_bot  := f4_b
        act_tm   := f4_tm
        act_bull := f4_u
        act_lbl  := "4h"
        act_tf   := "240"
    else if not na(f1_t)
        act_top  := f1_t
        act_bot  := f1_b
        act_tm   := f1_tm
        act_bull := f1_u
        act_lbl  := "1h"
        act_tf   := "60"
    else if not na(f30_t)
        act_top  := f30_t
        act_bot  := f30_b
        act_tm   := f30_tm
        act_bull := f30_u
        act_lbl  := "30m"
        act_tf   := "30"
    else if not na(f15_t)
        act_top  := f15_t
        act_bot  := f15_b
        act_tm   := f15_tm
        act_bull := f15_u
        act_lbl  := "15m"
        act_tf   := "15"
    else if not na(f5_t)
        act_top  := f5_t
        act_bot  := f5_b
        act_tm   := f5_tm
        act_bull := f5_u
        act_lbl  := "5m"
        act_tf   := "5"

// ═══════════════════════════════════════════════════════════════════
// CURRENT TF
// ═══════════════════════════════════════════════════════════════════
[tf_at, tf_ab, tf_atm, tf_at_ub, tf_mt, tf_mb, tf_mtm, tf_mt_ub] = f_scan_tf(lookback)

float tf_top  = na
float tf_bot  = na
int   tf_tm   = na
bool  tf_bull = false

if not na(tf_at)
    tf_top  := tf_at
    tf_bot  := tf_ab
    tf_tm   := tf_atm
    tf_bull := tf_at_ub
else if not na(tf_mt)
    tf_top  := tf_mt
    tf_bot  := tf_mb
    tf_tm   := tf_mtm
    tf_bull := tf_mt_ub

// ═══════════════════════════════════════════════════════════════════
// MITIGATION STATE
// Rules:
//   - Entry: any wick overlaps the remaining zone
//   - Tracking: candle body penetration depth (open/close, not wicks)
//   - vb update: on exit only, using min/max to guard against no-body-entry
//   - Full mitigation: body closes through entire remaining zone → done
//   - Shrink: permanent — box stays at remaining size even when price exits
// ═══════════════════════════════════════════════════════════════════
var float htf_vb     = na
var bool  htf_iz     = false
var float htf_ex     = na
var float htf_sv_top = na
var float htf_sv_bot = na
var bool  htf_bull   = false
var bool  htf_done   = false

var float tf_vb      = na
var bool  tf_iz      = false
var float tf_ex      = na
var float tf_sv_top  = na
var float tf_sv_bot  = na
var bool  tf_vb_bull = false
var bool  tf_done    = false

if barstate.isconfirmed
    // ── HTF mitigation ───────────────────────────────────────────
    if not na(act_top)
        if act_top != htf_sv_top or act_bot != htf_sv_bot
            htf_sv_top := act_top
            htf_sv_bot := act_bot
            htf_bull   := act_bull
            htf_vb     := act_bull ? act_top : act_bot
            htf_iz     := false
            htf_ex     := na
            htf_done   := false
        if not htf_done
            bool htf_inside = htf_bull ? (low <= htf_vb and high >= act_bot) : (high >= htf_vb and low <= act_top)
            if htf_inside
                float body_lo = math.min(open, close)
                float body_hi = math.max(open, close)
                if not htf_iz
                    htf_iz := true
                    htf_ex := htf_bull ? body_lo : body_hi
                else
                    htf_ex := htf_bull ? math.min(htf_ex, body_lo) : math.max(htf_ex, body_hi)
                // Body closed through the entire remaining zone → inversion, no longer valid
                bool htf_full = htf_bull ? body_lo <= act_bot : body_hi >= act_top
                if htf_full
                    htf_done := true
                    htf_iz   := false
            // Exit: close moves back outside the remaining zone
            bool htf_exited = htf_iz and (htf_bull ? close > htf_vb : close < htf_vb)
            if htf_exited
                htf_iz := false
                // min/max guards: if body never entered zone, vb stays unchanged
                htf_vb := htf_bull ? math.min(htf_ex, htf_vb) : math.max(htf_ex, htf_vb)
    else
        htf_sv_top := na
        htf_sv_bot := na
        htf_iz     := false
        htf_vb     := na
        htf_ex     := na
        htf_done   := false

    // ── TF mitigation ────────────────────────────────────────────
    if not na(tf_top)
        if tf_top != tf_sv_top or tf_bot != tf_sv_bot
            tf_sv_top  := tf_top
            tf_sv_bot  := tf_bot
            tf_vb_bull := tf_bull
            tf_vb      := tf_bull ? tf_top : tf_bot
            tf_iz      := false
            tf_ex      := na
            tf_done    := false
        if not tf_done
            bool tf_inside = tf_vb_bull ? (low <= tf_vb and high >= tf_bot) : (high >= tf_vb and low <= tf_top)
            if tf_inside
                float body_lo = math.min(open, close)
                float body_hi = math.max(open, close)
                if not tf_iz
                    tf_iz := true
                    tf_ex := tf_vb_bull ? body_lo : body_hi
                else
                    tf_ex := tf_vb_bull ? math.min(tf_ex, body_lo) : math.max(tf_ex, body_hi)
                bool tf_full = tf_vb_bull ? body_lo <= tf_bot : body_hi >= tf_top
                if tf_full
                    tf_done := true
                    tf_iz   := false
            bool tf_exited = tf_iz and (tf_vb_bull ? close > tf_vb : close < tf_vb)
            if tf_exited
                tf_iz := false
                tf_vb := tf_vb_bull ? math.min(tf_ex, tf_vb) : math.max(tf_ex, tf_vb)
    else
        tf_sv_top  := na
        tf_sv_bot  := na
        tf_iz      := false
        tf_vb      := na
        tf_ex      := na
        tf_done    := false

// ═══════════════════════════════════════════════════════════════════
// DISPLAY — every bar
// Box shrinks permanently once partial mitigation occurs.
// Fully mitigated zones (inversion) are removed entirely.
// ═══════════════════════════════════════════════════════════════════
var box   active_box  = na
var float prev_top    = na
var float prev_bot    = na
var box   tf_box      = na
var float tf_prev_top = na
var float tf_prev_bot = na

right_ms = time + timeframe.in_seconds() * 1000 * (extend_bars + 1)

// — HTF display ———————————————————————————————————————————————————
bool  htf_partial  = not na(htf_vb) and (htf_bull ? htf_vb < act_top : htf_vb > act_bot)
float htf_disp_top = (htf_partial and htf_bull)      ? htf_vb : act_top
float htf_disp_bot = (htf_partial and not htf_bull)  ? htf_vb : act_bot
color htf_bg       = htf_iz ? zone_col_in : zone_col
bool  zone_changed = act_top != prev_top or act_bot != prev_bot
bool  zone_active  = show_htf_box and not na(act_top) and not htf_done

if zone_active
    if na(active_box) or zone_changed
        if not na(active_box)
            box.delete(active_box)
        active_box := box.new(
             left         = act_tm,
             top          = htf_disp_top,
             right        = right_ms,
             bottom       = htf_disp_bot,
             xloc         = xloc.bar_time,
             bgcolor      = htf_bg,
             border_color = color.new(color.white, 100),
             border_width = 0,
             text         = show_label ? act_lbl : "",
             text_color   = label_col,
             text_size    = f_size(label_size),
             text_halign  = text.align_right,
             text_valign  = text.align_center)
        prev_top := act_top
        prev_bot := act_bot
    else
        box.set_top(active_box, htf_disp_top)
        box.set_bottom(active_box, htf_disp_bot)
        box.set_bgcolor(active_box, htf_bg)
        box.set_right(active_box, right_ms)
else
    if not na(active_box)
        box.delete(active_box)
        active_box := na
    prev_top := na
    prev_bot := na

// — TF display ————————————————————————————————————————————————————
bool  tf_partial  = not na(tf_vb) and (tf_vb_bull ? tf_vb < tf_top : tf_vb > tf_bot)
float tf_disp_top = (tf_partial and tf_vb_bull)      ? tf_vb : tf_top
float tf_disp_bot = (tf_partial and not tf_vb_bull)  ? tf_vb : tf_bot
color tf_bg       = tf_iz ? tf_zone_col_in : tf_zone_col
bool  draw_tf_box = show_tf_box and not na(tf_top) and not tf_done
bool  tf_changed  = tf_top != tf_prev_top or tf_bot != tf_prev_bot

if draw_tf_box
    if na(tf_box) or tf_changed
        if not na(tf_box)
            box.delete(tf_box)
        tf_box := box.new(
             left         = tf_tm,
             top          = tf_disp_top,
             right        = right_ms,
             bottom       = tf_disp_bot,
             xloc         = xloc.bar_time,
             bgcolor      = tf_bg,
             border_color = color.new(color.white, 100),
             border_width = 0,
             text         = show_label ? f_tf_label(timeframe.period) : "",
             text_color   = label_col,
             text_size    = f_size(label_size),
             text_halign  = text.align_right,
             text_valign  = text.align_center)
        tf_prev_top := tf_top
        tf_prev_bot := tf_bot
    else
        box.set_top(tf_box, tf_disp_top)
        box.set_bottom(tf_box, tf_disp_bot)
        box.set_bgcolor(tf_box, tf_bg)
        box.set_right(tf_box, right_ms)
else
    if not na(tf_box)
        box.delete(tf_box)
        tf_box := na
    tf_prev_top := na
    tf_prev_bot := na
