//@version=6
// AW Indicator — Full
// Combines: CISD+IFVG, Session Liquidity, HTF FVG, Trailing Stop, EQH/EQL, Swing Divergence
indicator("AW Indicator — Full", shorttitle="AW Full", overlay=true,
     max_bars_back=1000, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// ═══════════════════════════════════════════════════════════════════
// SHARED HELPERS
// ═══════════════════════════════════════════════════════════════════

f_text_size(string s) =>
    switch s
        "tiny"   => size.tiny
        "small"  => size.small
        "normal" => size.normal
        "large"  => size.large
        => size.tiny

f_size(string s) =>
    switch s
        "tiny"   => size.tiny
        "small"  => size.small
        "normal" => size.normal
        "large"  => size.large
        => size.small

