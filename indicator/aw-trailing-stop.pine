//@version=6
// AW Trailing Stop — Protected Levels
// Bullish: FVG forms → price taps it → is_lower_low fires → lower low = protected low
//          CISD confirms (close > highest_open of prior bearish leg) → draw level
// Bearish: mirror logic. is_higher_high fires → higher high = protected high.
// Mitigation: real-time (every tick), not just on close.
indicator("AW Trailing Stop — Protected Levels", overlay=true, max_lines_count=500, max_labels_count=200)

// ─── Settings ──────────────────────────────────────────────────────────────
var string G = "Trailing Stop"
enable       = input.bool(true,     "Enable",              group=G)
require_fvg  = input.bool(true,     "Require FVG Tap",     group=G)
max_shown    = input.int(3,         "Max Levels Shown",    group=G, minval=1, maxval=10)
line_width   = input.int(2,         "Line Width",          group=G, minval=1, maxval=4)
color_bull   = input.color(#26a69a, "Protected Low Color", group=G)
color_bear   = input.color(#ef5350, "Protected High Color",group=G)

var string GL = "Labels"
show_lbl     = input.bool(true,              "Show Level Labels", group=GL)
lbl_bull     = input.string("Protected Low",  "Bull Label Text",  group=GL)
lbl_bear     = input.string("Protected High", "Bear Label Text",  group=GL)
lbl_size_str = input.string("Small",          "Label Size",       group=GL, options=["Tiny","Small","Normal","Large"])

var string GC = "CISD / Swing Detection"
cisd_window  = input.int(4,   "Trigger Window",    group=GC, minval=1, maxval=20)
max_leg      = input.int(10,  "Max Leg Length",    group=GC, minval=1, maxval=30)
fvg_lookback = input.int(100, "FVG Lookback (bars)", group=GC, minval=1, maxval=500)

var string GPX = "Proximity Filter"
prox_dedupe    = input.bool(true,  "Remove Duplicate Levels", group=GPX)
prox_threshold = input.float(10.0, "Proximity Threshold (points)", group=GPX, minval=0.0, step=0.1)

lbl_sz = switch lbl_size_str
    "Tiny"   => size.tiny
    "Small"  => size.small
    "Normal" => size.normal
    "Large"  => size.large
    => size.small

// ─── FVG arrays ───────────────────────────────────────────────────────────
var float[] bull_fvg_bot  = array.new_float(0)
var float[] bull_fvg_top  = array.new_float(0)
var float[] bull_fvg_vtop = array.new_float(0)  // remaining unmitigated top
var int[]   bull_fvg_bar  = array.new_int(0)
var float[] bear_fvg_bot  = array.new_float(0)
var float[] bear_fvg_top  = array.new_float(0)
var float[] bear_fvg_vbot = array.new_float(0)  // remaining unmitigated bot
var int[]   bear_fvg_bar  = array.new_int(0)

// ─── CISD pending state ────────────────────────────────────────────────────
lowest_10  = ta.lowest(low,  10)[1]
highest_10 = ta.highest(high, 10)[1]

var bool  pend_bull          = false
var int   pend_bull_bar      = 0
var float pend_bull_cisd     = na
var int   pend_bull_cisd_src = 0   // bar_index of the highest_open candle (left border)

var bool  pend_bear          = false
var int   pend_bear_bar      = 0
var float pend_bear_cisd     = na
var int   pend_bear_cisd_src = 0   // bar_index of the lowest_open candle (left border)

// ─── Active level arrays ───────────────────────────────────────────────────
var line[]  bull_lines = array.new_line()
var label[] bull_lbls  = array.new_label()
var float[] bull_lvls  = array.new_float()

var line[]  bear_lines = array.new_line()
var label[] bear_lbls  = array.new_label()
var float[] bear_lvls  = array.new_float()

// ─── Confirmed-bar logic ───────────────────────────────────────────────────
if barstate.isconfirmed

    // 1. Detect new FVGs
    if low > high[2]
        array.push(bull_fvg_bot,  high[2])
        array.push(bull_fvg_top,  low)
        array.push(bull_fvg_vtop, low)
        array.push(bull_fvg_bar,  bar_index)
    if high < low[2]
        array.push(bear_fvg_bot,  high)
        array.push(bear_fvg_top,  low[2])
        array.push(bear_fvg_vbot, high)
        array.push(bear_fvg_bar,  bar_index)

    // 2. CISD swing detection (runs before FVG purge so just_set flags are ready)
    float recent_swing_low = na
    for j = 2 to 50
        if close[j] < open[j] and close[j-1] > open[j-1]
            recent_swing_low := math.min(low[j], low[j-1])
            break

    float recent_swing_high = na
    for j = 2 to 50
        if close[j] > open[j] and close[j-1] < open[j-1]
            recent_swing_high := math.max(high[j], high[j-1])
            break

    is_lower_low   = low[0]  < lowest_10  or (not na(recent_swing_low)  and low[0]  < recent_swing_low)
    is_higher_high = high[0] > highest_10 or (not na(recent_swing_high) and high[0] > recent_swing_high)

    // Bullish CISD setup: lower low (FVG tap check deferred to draw time)
    if is_lower_low
        int   bear_start          = -1
        float highest_open        = na
        int   highest_open_bar_j  = -1
        for j = 1 to 50
            if close[j] < open[j]
                bear_start := j
                break
        if bear_start >= 0
            for j = bear_start to bear_start + max_leg - 1
                if close[j] < open[j]
                    if na(highest_open) or open[j] > highest_open
                        highest_open       := open[j]
                        highest_open_bar_j := j
                else
                    break
        if not na(highest_open)
            pend_bull          := true
            pend_bull_bar      := bar_index
            pend_bull_cisd     := highest_open
            pend_bull_cisd_src := bar_index - highest_open_bar_j

    // Bearish CISD setup: higher high (FVG tap check deferred to draw time)
    if is_higher_high
        int   bull_start         = -1
        float lowest_open        = na
        int   lowest_open_bar_j  = -1
        for j = 1 to 50
            if close[j] > open[j]
                bull_start := j
                break
        if bull_start >= 0
            for j = bull_start to bull_start + max_leg - 1
                if close[j] > open[j]
                    if na(lowest_open) or open[j] < lowest_open
                        lowest_open       := open[j]
                        lowest_open_bar_j := j
                else
                    break
        if not na(lowest_open)
            pend_bear          := true
            pend_bear_bar      := bar_index
            pend_bear_cisd     := lowest_open
            pend_bear_cisd_src := bar_index - lowest_open_bar_j

    // 3. Purge inverted/expired FVGs; update partial mitigation
    // While pend_bull/pend_bear is active, freeze vtop/vbot — only a close
    // through the FVG invalidates it during the manipulation leg.
    int nb = array.size(bull_fvg_bot)
    if nb > 0
        for i = nb - 1 to 0
            float bot_i  = array.get(bull_fvg_bot,  i)
            float vtop_i = array.get(bull_fvg_vtop, i)
            if close < bot_i or bar_index - array.get(bull_fvg_bar, i) > fvg_lookback
                array.remove(bull_fvg_bot,  i)
                array.remove(bull_fvg_top,  i)
                array.remove(bull_fvg_vtop, i)
                array.remove(bull_fvg_bar,  i)
            else if not pend_bull and low <= vtop_i
                float new_vtop = math.min(vtop_i, low)
                if new_vtop <= bot_i
                    array.remove(bull_fvg_bot,  i)
                    array.remove(bull_fvg_top,  i)
                    array.remove(bull_fvg_vtop, i)
                    array.remove(bull_fvg_bar,  i)
                else
                    array.set(bull_fvg_vtop, i, new_vtop)

    int nbr = array.size(bear_fvg_bot)
    if nbr > 0
        for i = nbr - 1 to 0
            float top_i  = array.get(bear_fvg_top,  i)
            float vbot_i = array.get(bear_fvg_vbot, i)
            if close > top_i or bar_index - array.get(bear_fvg_bar, i) > fvg_lookback
                array.remove(bear_fvg_bot,  i)
                array.remove(bear_fvg_top,  i)
                array.remove(bear_fvg_vbot, i)
                array.remove(bear_fvg_bar,  i)
            else if not pend_bear and high >= vbot_i
                float new_vbot = math.max(vbot_i, high)
                if new_vbot >= top_i
                    array.remove(bear_fvg_bot,  i)
                    array.remove(bear_fvg_top,  i)
                    array.remove(bear_fvg_vbot, i)
                    array.remove(bear_fvg_bar,  i)
                else
                    array.set(bear_fvg_vbot, i, new_vbot)

// ─── Drawing logic (every tick — real-time extension + mitigation) ─────────
if enable

    // Extend all active bull lines/labels to current bar
    int n_bull = array.size(bull_lines)
    if n_bull > 0
        for i = 0 to n_bull - 1
            ln = array.get(bull_lines, i)
            lb = array.get(bull_lbls, i)
            if not na(ln)
                line.set_x2(ln, bar_index)
            if not na(lb)
                label.set_x(lb, bar_index)

    // Extend all active bear lines/labels to current bar
    int n_bear = array.size(bear_lines)
    if n_bear > 0
        for i = 0 to n_bear - 1
            ln = array.get(bear_lines, i)
            lb = array.get(bear_lbls, i)
            if not na(ln)
                line.set_x2(ln, bar_index)
            if not na(lb)
                label.set_x(lb, bar_index)

    // Real-time mitigation: low breaks bull level → delete
    int n_bul = array.size(bull_lvls)
    if n_bul > 0
        for i = n_bul - 1 to 0
            lvl = array.get(bull_lvls, i)
            if not na(lvl) and low < lvl
                line.delete(array.get(bull_lines, i))
                lb = array.get(bull_lbls, i)
                if not na(lb)
                    label.delete(lb)
                array.remove(bull_lines, i)
                array.remove(bull_lbls,  i)
                array.remove(bull_lvls,  i)

    // Real-time mitigation: high breaks bear level → delete
    int n_bea = array.size(bear_lvls)
    if n_bea > 0
        for i = n_bea - 1 to 0
            lvl = array.get(bear_lvls, i)
            if not na(lvl) and high > lvl
                line.delete(array.get(bear_lines, i))
                lb = array.get(bear_lbls, i)
                if not na(lb)
                    label.delete(lb)
                array.remove(bear_lines, i)
                array.remove(bear_lbls,  i)
                array.remove(bear_lvls,  i)

    // CISD confirmation (confirmed bars only — no repainting)
    if barstate.isconfirmed

        if pend_bull
            bars_since = bar_index - pend_bull_bar
            if bars_since >= 0 and bars_since <= cisd_window
                if close > pend_bull_cisd
                    // Scan left border → right border for lowest wick
                    int   scan_range = math.max(bar_index - pend_bull_cisd_src, 0)
                    float d_low      = na
                    int   d_low_bar  = bar_index
                    for j = 0 to scan_range
                        if na(d_low) or low[j] < d_low
                            d_low     := low[j]
                            d_low_bar := bar_index - j
                    // FVG tap check: manipulation extreme (d_low) must enter unmitigated bull FVG
                    bool fvg_ok = not require_fvg
                    if require_fvg
                        int n_bfvg = array.size(bull_fvg_bot)
                        if n_bfvg > 0
                            for fi = 0 to n_bfvg - 1
                                if d_low <= array.get(bull_fvg_vtop, fi)
                                    fvg_ok := true
                                    break
                    pend_bull := false
                    if fvg_ok
                        // Global cap: remove oldest level across both types
                        while array.size(bull_lines) + array.size(bear_lines) >= max_shown
                            bool rm_bull = array.size(bull_lines) > 0 and (array.size(bear_lines) == 0 or line.get_x1(array.get(bull_lines, 0)) <= line.get_x1(array.get(bear_lines, 0)))
                            if rm_bull
                                line.delete(array.shift(bull_lines))
                                _lb = array.shift(bull_lbls)
                                if not na(_lb)
                                    label.delete(_lb)
                                array.shift(bull_lvls)
                            else if array.size(bear_lines) > 0
                                line.delete(array.shift(bear_lines))
                                _lb = array.shift(bear_lbls)
                                if not na(_lb)
                                    label.delete(_lb)
                                array.shift(bear_lvls)
                            else
                                break
                        new_ln = line.new(d_low_bar, d_low, bar_index, d_low,
                                          color=color_bull, width=line_width)
                        new_lb = show_lbl ? label.new(bar_index, d_low, lbl_bull,
                                                      yloc=yloc.price, style=label.style_label_left,
                                                      color=color.new(color_bull, 100),
                                                      textcolor=color_bull, size=lbl_sz) : na
                        array.push(bull_lines, new_ln)
                        array.push(bull_lbls,  new_lb)
                        array.push(bull_lvls,  d_low)
                        // Proximity dedup: keep lower protected low
                        if prox_dedupe
                            int   ni  = array.size(bull_lvls) - 1
                            float nv  = array.get(bull_lvls, ni)
                            int   del = -1
                            if ni > 0
                                for i = 0 to ni - 1
                                    if math.abs(nv - array.get(bull_lvls, i)) <= prox_threshold
                                        del := nv > array.get(bull_lvls, i) ? ni : i
                                        break
                            if del >= 0
                                line.delete(array.get(bull_lines, del))
                                lb_del = array.get(bull_lbls, del)
                                if not na(lb_del)
                                    label.delete(lb_del)
                                array.remove(bull_lines, del)
                                array.remove(bull_lbls,  del)
                                array.remove(bull_lvls,  del)
            else if bars_since > cisd_window
                pend_bull := false

        if pend_bear
            bars_since = bar_index - pend_bear_bar
            if bars_since >= 0 and bars_since <= cisd_window
                if close < pend_bear_cisd
                    // Scan left border → right border for highest wick
                    int   scan_range = math.max(bar_index - pend_bear_cisd_src, 0)
                    float d_high     = na
                    int   d_high_bar = bar_index
                    for j = 0 to scan_range
                        if na(d_high) or high[j] > d_high
                            d_high     := high[j]
                            d_high_bar := bar_index - j
                    // FVG tap check: manipulation extreme (d_high) must enter unmitigated bear FVG
                    bool fvg_ok = not require_fvg
                    if require_fvg
                        int n_bfvg = array.size(bear_fvg_bot)
                        if n_bfvg > 0
                            for fi = 0 to n_bfvg - 1
                                if d_high >= array.get(bear_fvg_vbot, fi)
                                    fvg_ok := true
                                    break
                    pend_bear := false
                    if fvg_ok
                        // Global cap: remove oldest level across both types
                        while array.size(bull_lines) + array.size(bear_lines) >= max_shown
                            bool rm_bull = array.size(bull_lines) > 0 and (array.size(bear_lines) == 0 or line.get_x1(array.get(bull_lines, 0)) <= line.get_x1(array.get(bear_lines, 0)))
                            if rm_bull
                                line.delete(array.shift(bull_lines))
                                _lb = array.shift(bull_lbls)
                                if not na(_lb)
                                    label.delete(_lb)
                                array.shift(bull_lvls)
                            else if array.size(bear_lines) > 0
                                line.delete(array.shift(bear_lines))
                                _lb = array.shift(bear_lbls)
                                if not na(_lb)
                                    label.delete(_lb)
                                array.shift(bear_lvls)
                            else
                                break
                        new_ln = line.new(d_high_bar, d_high, bar_index, d_high,
                                          color=color_bear, width=line_width)
                        new_lb = show_lbl ? label.new(bar_index, d_high, lbl_bear,
                                                      yloc=yloc.price, style=label.style_label_left,
                                                      color=color.new(color_bear, 100),
                                                      textcolor=color_bear, size=lbl_sz) : na
                        array.push(bear_lines, new_ln)
                        array.push(bear_lbls,  new_lb)
                        array.push(bear_lvls,  d_high)
                        // Proximity dedup: keep higher protected high
                        if prox_dedupe
                            int   ni  = array.size(bear_lvls) - 1
                            float nv  = array.get(bear_lvls, ni)
                            int   del = -1
                            if ni > 0
                                for i = 0 to ni - 1
                                    if math.abs(nv - array.get(bear_lvls, i)) <= prox_threshold
                                        del := nv < array.get(bear_lvls, i) ? ni : i
                                        break
                            if del >= 0
                                line.delete(array.get(bear_lines, del))
                                lb_del = array.get(bear_lbls, del)
                                if not na(lb_del)
                                    label.delete(lb_del)
                                array.remove(bear_lines, del)
                                array.remove(bear_lbls,  del)
                                array.remove(bear_lvls,  del)
            else if bars_since > cisd_window
                pend_bear := false
